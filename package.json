{
  "name": "illthorn",
  "productName": "illthorn",
  "version": "0.0.3",
  "description": "a modern FE for Gemstone IV",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start --enable-logging",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "rc": "yarn version prerelease && git push && git push --tags",
    "typecheck": "tsc --noEmit",
    "test": "VITE_CJS_IGNORE_WARNING=true vitest run --reporter=verbose --bail=1",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check": "yarn format && yarn lint && yarn typecheck && yarn test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": {
    "name": "Benjamin Clos",
    "email": "benjamin.clos@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@storybook/web-components-vite": "^9.1.2",
    "@types/debug": "^4.1.7",
    "@types/events": "^3",
    "@types/jsdom": "^21.1.7",
    "@types/mark.js": "^8.11.8",
    "@types/node": "^24.1.0",
    "@types/path-browserify": "^1",
    "@types/semver": "^7",
    "@vitest/ui": "2.1.9",
    "electron": "^37.2.4",
    "events": "^3.3.0",
    "jsdom": "^26.1.0",
    "path-browserify": "^1.0.1",
    "sass": "^1.58.3",
    "semver": "^7.7.2",
    "storybook": "^9.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3",
    "util": "^0.12.5",
    "vite": "^6.3.5",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@floating-ui/utils": "^0.2.10",
    "@lit-labs/virtualizer": "^2.1.1",
    "@shoelace-style/shoelace": "^2.20.1",
    "@types/keyboardjs": "^2.5.0",
    "debug": "^4.3.4",
    "dotenv": "^17.2.1",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.1.0",
    "keyboardjs": "^2.7.0",
    "lit": "^3.3.1",
    "mark.js": "^8.11.1",
    "saxophone": "^0.8.0",
    "ws": "^8.12.1"
  },
  "volta": {
    "node": "22.11.0",
    "yarn": "4.9.2"
  },
  "packageManager": "yarn@4.9.2"
}
