{
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": false,
    "module": "esnext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["./src/types/illthorn.d.ts", "vitest/globals"]
  },
  "include": ["src/**/*"]
}
